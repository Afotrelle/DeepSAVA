Bootstrap: docker
From: nvcr.io/nvidia/tensorflow:20.12-tf1-py3

%environment
    export TZ=Europe/Rome
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%post
    apt-get update -y
    apt-get install -y python3-pip python3-dev git build-essential
    ln -sf /usr/bin/python3 /usr/bin/python
    python -m pip install --upgrade pip
    python -m pip install numpy==1.19.5 scipy==1.5.2 keras==2.2.4 h5py pillow opencv-python

%labels
    Author DeepSAVA
    Version 1.0

%runscript
    exec python "$@"
